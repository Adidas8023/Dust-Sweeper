# EVM signer (0x-prefixed hex). Browser-imported keys can be used instead.
PRIVATE_KEY_EVM=

# Multi-wallet EVM signers (comma-separated 0x-prefixed hex). Takes precedence
# over PRIVATE_KEY_EVM when set. Example value:
# 0x<evm-key-1>,0x<evm-key-2>
PRIVATE_KEYS_EVM=

# Solana signer (base58 secret key) — optional unless Solana is used.
PRIVATE_KEY_SOL=

# Multi-wallet Solana signers (comma-separated base58 secret keys). Takes
# precedence over PRIVATE_KEY_SOL when set.
PRIVATE_KEYS_SOL=

# Optional direct OKX DEX API fallback credentials
# (https://www.okx.com/web3/dev). OnchainOS CLI is the primary data source.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# Optional: route OKX Web3 API requests through an HTTP/HTTPS proxy.
# Option A: set OKX_PROXY_URL directly.
# Example: OKX_PROXY_URL=http://127.0.0.1:7897
OKX_PROXY_URL=
OKX_PROXY_TLS_REJECT_UNAUTHORIZED=1

# Option B: run `pnpm proxy:okx` to start a local proxy that forwards to a
# remote HTTP/HTTPS upstream proxy. Keep real credentials in .env only.
OKX_UPSTREAM_PROXY_URL=
OKX_UPSTREAM_PROXY_TLS_REJECT_UNAUTHORIZED=1
OKX_LOCAL_PROXY_HOST=127.0.0.1
OKX_LOCAL_PROXY_PORT=7897

# Alchemy API key — auto-builds RPC URLs for supported Alchemy-hosted chains.
# Get one at https://dashboard.alchemy.com/ (free tier covers this app).
ALCHEMY_API_KEY=

# Optional per-chain RPC override (highest priority; bypasses Alchemy)
RPC_ETHEREUM=
RPC_ARBITRUM=
RPC_BASE=
RPC_POLYGON=
RPC_OPTIMISM=
RPC_AVALANCHE=
RPC_UNICHAIN=
RPC_LINEA=
RPC_SONIC=
RPC_MONAD=
RPC_SOLANA=
